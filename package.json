{
  "name": "simple-electron",
  "version": "0.0.1",
  "description": "A simple electron app",
  "main": "src/main.js",
  "type": "module",
  "permissions": [
    "notifications"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "SET NODE_ENV=development && electron .",
    "format": "prettier --write ./src/**/*.{js,css,html} --end-of-line auto",
    "build": "electron-builder"
  },
  "author": "Sisyphus",
  "license": "ISC",
  "devDependencies": {
    "chokidar": "5.0.0",
    "electron": "41.2.0",
    "electron-builder": "^26.8.1",
    "electron-reloader": "^1.2.3",
    "glob": "13.0.6"
  },
  "config": {
    "electron_mirror": "https://npmmirror.com/mirrors/electron/",
    "electron_builder_binaries_mirror": "https://npmmirror.com/mirrors/electron-builder-binaries/"
  }
}
